<link rel="preconnect" href="https://googleapis.com">
<link rel="preconnect" href="https://gstatic.com" crossorigin>
<link href="https://googleapis.com/css2?family=Cinzel:wght@400;700&family=Montserrat:wght@200;400;600&family=Playfair+Display:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet">

<style>
/* 
========================================
1. DESIGN SYSTEM & VARIABLES
========================================
*/
:root {
    --gold-primary: #c5a059;
    --gold-secondary: #e0b973;
    --gold-deep: #8a6d3b;
    --navy-black: #02080c;
    --navy-dark: #040d12;
    --navy-mid: #0a1a24;
    --white-pure: #ffffff;
    --white-soft: #f4fafc;
    --text-muted: #a0a0a0;
    --glass-bg: rgba(255, 255, 255, 0.02);
    --glass-border: rgba(255, 255, 255, 0.08);
    --shadow-lg: 0 50px 100px rgba(0,0,0,0.9);
    --transition-slow: all 0.8s cubic-bezier(0.19, 1, 0.22, 1);
    --transition-fast: all 0.3s ease;
}

/* 
========================================
2. GLOBAL RESET & SCROLLBAR
========================================
*/
* { box-sizing: border-box; margin: 0; padding: 0; outline: none; }
html { scroll-behavior: smooth; font-size: 16px; }

::-webkit-scrollbar { width: 6px; }
::-webkit-scrollbar-track { background: var(--navy-black); }
::-webkit-scrollbar-thumb { background: var(--gold-primary); border-radius: 10px; }

body {
    background-color: var(--navy-black);
    color: var(--white-soft);
    font-family: 'Montserrat', sans-serif;
    line-height: 1.8;
    overflow-x: hidden;
    cursor: none;
}

h1, h2, h3, .brand { font-family: 'Cinzel', serif; font-weight: 400; letter-spacing: 4px; }
p { font-family: 'Montserrat', sans-serif; font-weight: 200; }

/* 
========================================
3. CUSTOM CURSOR
========================================
*/
#cursor {
    position: fixed; width: 10px; height: 10px;
    background: var(--gold-primary); border-radius: 50%;
    pointer-events: none; z-index: 1000000;
    transition: transform 0.1s ease;
}
#cursor-outline {
    position: fixed; width: 40px; height: 40px;
    border: 1px solid var(--gold-primary); border-radius: 50%;
    pointer-events: none; z-index: 1000000;
    transition: transform 0.15s ease-out;
}

/* 
========================================
4. NAVIGATION (THE TOPBAR)
========================================
*/
.topbar {
    position: fixed; top: 0; left: 0; width: 100%;
    padding: 1.5rem 6%; display: flex;
    justify-content: space-between; align-items: center;
    background: rgba(2, 8, 12, 0.9);
    backdrop-filter: blur(30px);
    z-index: 99999;
    border-bottom: 1px solid var(--glass-border);
}

.brand { font-size: 1.6rem; color: var(--gold-primary); text-decoration: none; transition: var(--transition-fast); }
.brand:hover { color: var(--white-pure); letter-spacing: 6px; }

.nav-links { display: flex; gap: 3.5rem; list-style: none; }
.nav-links a {
    color: var(--white-pure); text-decoration: none;
    font-size: 0.7rem; font-weight: 600; text-transform: uppercase;
    letter-spacing: 3px; position: relative;
}
.nav-links a::after {
    content: ''; position: absolute; bottom: -5px; left: 0;
    width: 0; height: 1px; background: var(--gold-primary);
    transition: var(--transition-fast);
}
.nav-links a:hover::after { width: 100%; }

#bookNowBtn {
    border: 1px solid var(--gold-primary);
    padding: 12px 35px; border-radius: 0;
    color: var(--gold-primary); text-transform: uppercase;
    font-weight: 700; transition: var(--transition-fast);
}
#bookNowBtn:hover { background: var(--gold-primary); color: var(--navy-black); }

/* 
========================================
5. HERO SECTION & ANIMATIONS
========================================
*/
.hero {
    height: 100vh; width: 100%; display: flex;
    align-items: center; justify-content: center;
    position: relative; overflow: hidden;
    background: url("img.webp") center/cover no-repeat fixed;
}
.hero-overlay {
    position: absolute; inset: 0;
    background: linear-gradient(to bottom, rgba(2,8,12,0.3) 0%, rgba(2,8,12,1) 100%);
    z-index: 2;
}

.hero-content {
    position: relative; z-index: 10; text-align: center;
    max-width: 800px; padding: 0 20px;
}

.hero-content h1 {
    font-size: 4.5rem; line-height: 1.2; margin-bottom: 2rem;
    text-shadow: 0 10px 30px rgba(0,0,0,0.5);
    animation: slideUp 2s cubic-bezier(0.19, 1, 0.22, 1);
}

@keyframes slideUp {
    from { opacity: 0; transform: translateY(100px); }
    to { opacity: 1; transform: translateY(0); }
}

/* 
========================================
6. THE LOGIN PORTAL (GLASSMISM)
========================================
*/
.login-card {
    background: var(--glass-bg); padding: 4.5rem;
    backdrop-filter: blur(40px); border: 1px solid var(--glass-border);
    box-shadow: var(--shadow-lg); width: 480px; margin: 0 auto;
}

.login-card input {
    width: 100%; padding: 18px; margin-bottom: 1.5rem;
    background: rgba(255,255,255,0.03); border: 1px solid var(--glass-border);
    color: var(--white-pure); font-size: 0.8rem; letter-spacing: 2px;
}
.login-card input:focus { border-color: var(--gold-primary); background: rgba(255,255,255,0.06); }

.btn-primary {
    width: 100%; padding: 18px; background: var(--gold-primary);
    border: none; color: var(--navy-black); font-weight: 700;
    text-transform: uppercase; letter-spacing: 4px; cursor: pointer;
}

/* 
========================================
7. ROOM GALLERY SECTION
========================================
*/
.rooms-section { padding: 150px 6%; background: var(--navy-dark); }
.section-header { text-align: center; margin-bottom: 100px; }
.section-header span { color: var(--gold-primary); text-transform: uppercase; letter-spacing: 8px; font-size: 0.7rem; }
.section-header h2 { font-size: 3rem; margin-top: 1rem; }

.room-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 40px; }
.room-card { 
    position: relative; overflow: hidden; height: 550px; 
    border: 1px solid var(--glass-border);
}
.room-card img { width: 100%; height: 100%; object-fit: cover; transition: var(--transition-slow); }
.room-card:hover img { transform: scale(1.1); filter: brightness(0.6); }

.room-info {
    position: absolute; bottom: 0; left: 0; width: 100%;
    padding: 40px; background: linear-gradient(to top, rgba(2,8,12,1), transparent);
    transform: translateY(100px); opacity: 0; transition: var(--transition-slow);
}
.room-card:hover .room-info { transform: translateY(0); opacity: 1; }

/* 
========================================
8. SPA & WELLNESS
========================================
*/
.spa-section { 
    display: flex; align-items: center; gap: 100px; 
    padding: 150px 6%; background: var(--navy-mid);
}
.spa-image { flex: 1; height: 700px; border: 1px solid var(--gold-primary); padding: 20px; }
.spa-image img { width: 100%; height: 100%; object-fit: cover; }
.spa-text { flex: 1; }
.spa-text h2 { font-size: 3.5rem; margin-bottom: 2rem; }

/* 
========================================
9. THE GRAND DINING MENU
========================================
*/
.dining-section { padding: 150px 6%; text-align: center; }
.menu-grid { 
    display: grid; grid-template-columns: 1fr 1fr; gap: 80px; 
    text-align: left; max-width: 1200px; margin: 80px auto 0;
}
.menu-item { margin-bottom: 40px; border-bottom: 1px dashed var(--glass-border); padding-bottom: 20px; }
.menu-item h4 { color: var(--gold-primary); font-size: 1.2rem; display: flex; justify-content: space-between; }
.menu-item p { font-size: 0.8rem; color: var(--text-muted); margin-top: 10px; }

/* 
========================================
10. FOOTER ARCHITECTURE
========================================
*/
footer {
    background: var(--navy-black); padding: 100px 6% 50px;
    border-top: 1px solid var(--glass-border);
}
.footer-main {
    display: grid; grid-template-columns: repeat(4, 1fr); gap: 60px;
    margin-bottom: 80px;
}
.footer-col h3 { color: var(--gold-primary); font-size: 1rem; margin-bottom: 30px; }
.footer-col ul { list-style: none; }
.footer-col ul li { margin-bottom: 15px; font-size: 0.8rem; opacity: 0.6; cursor: pointer; }
.footer-col ul li:hover { opacity: 1; color: var(--gold-primary); }

/* 
========================================
11. MODAL (ENQUIRIES)
========================================
*/
.modal-overlay {
    display: none; position: fixed; inset: 0;
    background: rgba(2,8,12,0.98); z-index: 100000;
    backdrop-filter: blur(20px); place-items: center;
}
.modal-content {
    background: var(--navy-dark); border: 1px solid var(--glass-border);
    padding: 5rem; width: 700px; position: relative;
}
.close-modal {
    position: absolute; top: 30px; right: 40px;
    font-size: 3rem; color: var(--gold-primary); cursor: pointer;
}

</style>
